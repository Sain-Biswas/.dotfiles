{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "ignore-gtk-theme": true,

  "positionX": "right",
  "positionY": "top",

  "widgets": ["title", "dnd", "notifications", "mpris", "volume"],

  "layer": "overlay",
  "layer-shell": true,
  "layer-shell-cover-screen": true,

  "cssPriority": "user",

  "control-center-layer": "top",

  "control-center-margin-top": 0,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,

  "notification-2fa-action": true,
  "notification-inline-replies": true,

  "notification-body-image-height": 120,
  "notification-body-image-width": 220,

  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,

  "fit-to-screen": true,
  "relative-timestamps": true,

  "control-center-width": 420,
  "control-center-height": 580,
  "notification-window-width": 420,

  "keyboard-shortcuts": true,
  "notification-grouping": true,

  "image-visibility": "when-available",
  "transition-time": 180,

  "hide-on-clear": true,
  "hide-on-action": true,

  "text-empty": "No recent notifications",

  "script-fail-notify": true,

  "scripts": {
    "example-script": {
      "app-name": "example.app.id",
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    },
    "example-action-script": {
      "app-name": "example.app.id",
      "exec": "echo 'Do something actionable!'",
      "urgency": "Normal",
      "run-on": "action"
    }
  },

  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Normal",
      "app-name": "example.app.id"
    }
  },

  "widget-config": {
    "notifications": {
      "vexpand": true
    },

    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟"
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "mpris": {
      "blacklist": ["org.mpris.MediaPlayer2.playerctld"],
      "autohide": true,
      "show-album-art": "when-available",
      "loop-carousel": true
    },

    "volume": {
      "show-per-app": true,
      "label": "",
      "expand-button-label": "󰞖",
      "collapse-button-label": "󰞙",
      "empty-list-label": "󰝾"
    }
  }
}
