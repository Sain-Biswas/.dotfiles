{
  "clock": {
    "interval": 30,

    "format": "  {:%I:%M %p}",
    "format-alt": "  {:%A, %B %Od %Y}",

    "tooltip-format": "<tt><small>{calendar}</small></tt>",

    "calendar": {
      "mode": "month",
      "mode-mon-col": 4,
      "weeks-pos": "left",

      "format": {
        "months": "<span color='{{ colors.primary.default.hex }}'><b>{}</b></span>",
        "days": "<span color='{{ colors.on_surface.default.hex }}'><b>{}</b></span>",
        "weeks": "<span color='{{ colors.secondary.default.hex }}'><b>W{}</b></span>",
        "weekdays": "<span color='{{ colors.tertiary.default.hex }}'><b>{}</b></span>",
        "today": "<span color='{{ colors.error.default.hex }}'><b><u>{}</u></b></span>",
      },
    },

    "actions": {
      "on-click-middle": "shift_reset",
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
  },
}
