# widely used commands
alias c="clear"
alias vi="nvim"
alias vim="nvim"
alias grep="grep --color=auto"
alias mkdir="mkdir -p"
alias code="code-insiders"


# directory navigation shortcuts
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."

# eza custom aliases
alias l="eza -lha --icons=auto"
alias ls="eza --icons=auto -Ga"
alias lt="eza -lTa --git-ignore"

# git aliases
alias gc="git commit -m"
alias gs="git status"
alias gss="git status -s"
alias gl="git log --oneline"
alias gll="git log"
alias gtree="git log --oneline --graph --all"
